{
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "model": "sonnet",
  "language": "Vietnamese",
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read",
      "Write",
      "WebSearch",
      "WebFetch",
      "mcp__*",
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(uv sync*)",
      "Bash(uv lock*)",
      "Bash(uv run pytest*)",
      "Bash(uv run ruff*)",
      "Bash(bun install*)",
      "Bash(bun test*)",
      "Bash(bun run lint*)",
      "Bash(bun run build*)"
    ],
    "deny": [
      "Read(**/.ssh*)",
      "Write(**/.ssh*)",
      "Read(**/.gnupg*)",
      "Write(**/.gnupg*)",
      "Read(**/.aws/**)",
      "Write(**/.aws/**)",
      "Read(**/.config/gcloud/**)",
      "Write(**/.config/gcloud/**)",
      "Read(**/.kube/**)",
      "Write(**/.kube/**)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Read(**/.netrc)",
      "Read(**/.env*)",
      "Write(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.key)",
      "Read(**/*secret*)",
      "Write(**/*secret*)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(socat *)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(doas *)",
      "Bash(chown *)",
      "Bash(chmod *)",
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git remote *)",
      "Bash(git tag *)",
      "Bash(git rebase *)",
      "Bash(git merge *)",
      "Bash(git cherry-pick *)",
      "Bash(git reset *)",
      "Bash(git clean *)",
      "Bash(docker *)",
      "Bash(kubectl *)",
      "Bash(terraform *)",
      "Bash(aws *)",
      "Bash(gcloud *)",
      "Bash(az *)",
      "Bash(uv pip install *)",
      "Bash(uv tool install *)",
      "Bash(bun add -g *)",
      "Bash(bunx *)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(uv add *)",
      "Bash(uv remove *)",
      "Bash(bun add *)",
      "Bash(bun remove *)",
      "Bash(bun update *)"
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "skill-creator@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  }
}